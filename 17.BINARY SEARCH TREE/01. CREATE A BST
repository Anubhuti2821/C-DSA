/*
Problem: Build a Binary Search Tree (BST)

Description:
Given an array of integers, build a Binary Search Tree by inserting
each element into the BST. For every node:
- Values smaller than the current node go to the left subtree.
- Values greater than or equal to the current node go to the right subtree.
*/

class Solution {
public:
    TreeNode* insert(TreeNode* root, int val) {
        if (root == nullptr)
            return new TreeNode(val);

        if (val < root->val)
            root->left = insert(root->left, val);
        else
            root->right = insert(root->right, val);

        return root;
    }

    TreeNode* buildBST(vector<int>& nums) {
        TreeNode* root = nullptr;

        for (int val : nums)
            root = insert(root, val);

        return root;
    }
};

/*
Time Complexity:
- Average Case: O(n log n)
- Worst Case: O(n^2)

Space Complexity:
- Average Case: O(log n) (recursive call stack)
- Worst Case: O(n)

Possible Optimization:
If the input array is already sorted and a height-balanced BST is required,
construct the BST by recursively choosing the middle element as the root.
This approach builds the tree in O(n) time.
*/
